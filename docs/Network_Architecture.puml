@startuml
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

title Network Architecture (sample-vpc)

node "VPC: 10.0.0.0/16" {

    rectangle "Availability Zone: 1a" as az1a {
        package "Public Subnet (10.0.0.0/20)" {
            [ALB] as alb
            [NAT Gateway 01] as nat1
        }
        package "Private Subnet (10.0.64.0/20)" {
            [WebServer 01] as web1
        }
        ' DBのIPはスクリプトに合わせて調整が必要ですが、一旦名前のみにします
        package "DB Subnet 1a" {
            database "DB Master" as db1
        }
    }

    rectangle "Availability Zone: 1c" as az1c {
        package "Public Subnet (10.0.16.0/20)" {
            [Bastion] as bastion
            [NAT Gateway 02] as nat2
        }
        package "Private Subnet (10.0.80.0/20)" {
            [WebServer 02] as web2
        }
        package "DB Subnet 1c" {
            database "DB Standby" as db2
        }
    }
}

' 通信フロー
User --> alb
User --> bastion
bastion -[#blue]-> web1
bastion -[#blue]-> web2
alb --> web1
alb --> web2
web1 --> db1
web2 --> db1
db1 <-> db2 : Sync

@enduml
