@startuml
' アイコン読み込みを一旦やめて標準の四角形で書く
skinparam linetype ortho
skinparam shadowing false

node "VPC: sample-vpc (10.0.0.0/16)" {

    rectangle "AZ-1a" as az1a {
        package "Public Subnet 1a" {
            [ALB] as alb
            [NAT Gateway 01] as nat1
        }
        package "Private Subnet 1a" {
            [WebServer 01] as web1
        }
        package "DB Subnet 1a" {
            database "DB Master" as db1
        }
    }

    rectangle "AZ-1c" as az1c {
        package "Public Subnet 1c" {
            [Bastion] as bastion
            [NAT Gateway 02] as nat2
        }
        package "Private Subnet 1c" {
            [WebServer 02] as web2
        }
        package "DB Subnet 1c" {
            database "DB Standby" as db2
        }
    }
}

' 通信経路
User --> alb : HTTP(80)
User --> bastion : SSH(22)
bastion -[#blue]-> web1 : SSH
bastion -[#blue]-> web2 : SSH
alb --> web1
alb --> web2
web1 --> db1
web2 --> db1
db1 <-> db2 : Sync

@enduml
